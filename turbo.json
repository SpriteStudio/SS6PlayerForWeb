{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {},
    "test": {},
    "clean": {
      "cache": false
    },
    "docs": {
      "outputs": ["../../docs/**"]
    },
    "deploy": {
      "dependsOn": ["build"]
    }
  }
}
